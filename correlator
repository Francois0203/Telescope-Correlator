#!/bin/bash
# Telescope Correlator — usage: ./correlator [build|test|help]

IMAGE="telescope-correlator"

case "${1:-start}" in
    build)
        echo "Building Docker image..."
        docker build -f app/Dockerfile -t "$IMAGE" .
        ;;

    test)
        if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
            echo "Image not found. Run './correlator build' first."; exit 1
        fi
        docker run --rm \
            -v "$(pwd):/workspace" \
            -e PYTHONPATH=/workspace/app/src:/usr/local/lib/python3.11/site-packages \
            -w /workspace "$IMAGE" pytest tests_harness/ -v
        ;;

    help|-h|--help)
        echo "Usage: ./correlator [build|test|help]"
        echo "  build   Build the Docker image"
        echo "  test    Run the test suite"
        echo "  help    Show this message"
        echo "  (none)  Start the interactive CLI  (default)"
        ;;

    start|"")
        if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
            echo "Image not found. Run './correlator build' first."; exit 1
        fi
        docker run -it --rm -v "$(pwd)/workspace:/workspace" "$IMAGE" python -m correlator
        ;;

    *)
        echo "Unknown command: $1"
        echo "Run './correlator help' for usage."
        exit 1
        ;;
esac
